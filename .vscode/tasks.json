{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Backend: Uvicorn",
      "type": "shell",
      "command": "./.venv/bin/python -m uvicorn app.main:app --host 0.0.0.0 --port 8001",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": [
          {
            "regexp": ".*"
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Started server process|Uvicorn running on",
          "endsPattern": "Uvicorn running on"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "backend"
      }
    },
    {
      "label": "Frontend: Next Dev",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/frontend",
        "env": {
          "WATCHPACK_POLLING": "true",
          "NEXT_TELEMETRY_DISABLED": "1"
        }
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": [
          {
            "regexp": ".*"
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Starting\\.\\.\\.|Next\\.js|✓ Starting",
          "endsPattern": "Local:|Ready in"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "frontend"
      }
    },
    {
      "label": "Start App (Auto)",
      "type": "shell",
      "command": "echo Starting app...",
      "dependsOn": ["Backend: Uvicorn", "Frontend: Next Dev"],
      "dependsOrder": "parallel",
      "runOptions": {
        "runOn": "folderOpen"
      },
      "presentation": {
        "reveal": "never",
        "panel": "shared"
      }
    }
  ],
  "compounds": [
    {
      "label": "Start App",
      "dependsOn": ["Backend: Uvicorn", "Frontend: Next Dev"],
      "stopAll": true
    }
  ]
}
