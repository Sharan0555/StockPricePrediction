from __future__ import annotations

from typing import Dict

import numpy as np

from app.ml.models.lstm_model import LSTMStockModel


class PredictionEngine:
    """
    Facade for running model inference.
    Currently only uses LSTM; later we can add GRU, Transformer, and ensembles.
    """

    def __init__(self) -> None:
        self.lstm_model = LSTMStockModel()

    def predict_next_price(self, closes: list[float]) -> Dict[str, float]:
        series = np.asarray(closes, dtype=float)
        lstm_pred = self.lstm_model.predict_sequence(series)

        # For now, ensemble is equal to lstm prediction.
        ensemble_pred = lstm_pred

        return {
            "lstm": lstm_pred,
            "ensemble": ensemble_pred,
        }


prediction_engine = PredictionEngine()

